# ============================================================
# 门窗安装管理系统 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# -------------------- 通用配置 --------------------
SECRET_KEY=your-secret-key-change-me-in-production-use-openssl-rand-hex-32
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# -------------------- MySQL 数据库 --------------------
MYSQL_ROOT_PASSWORD=door_root_2024
MYSQL_DATABASE=door_install_db
MYSQL_USER=door_user
MYSQL_PASSWORD=door_pass_2024
MYSQL_HOST=mysql
MYSQL_PORT=3306

# Django 数据库配置（使用 Docker 内部地址）
DB_ENGINE=django.db.backends.mysql
DB_NAME=door_install_db
DB_USER=door_user
DB_PASSWORD=door_pass_2024
DB_HOST=mysql
DB_PORT=3306

# 对外映射端口
MYSQL_PORT=3306

# -------------------- Redis 缓存 --------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 对外映射端口
REDIS_PORT=6379

# -------------------- JWT 认证 --------------------
JWT_SECRET_KEY=your-jwt-secret-key-change-me
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=604800

# -------------------- 阿里云 OSS（预留） --------------------
# OSS_ENABLED=false
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_CUSTOM_DOMAIN=

# -------------------- 飞书集成 --------------------
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# FEISHU_VERIFICATION_TOKEN=
# FEISHU_BOT_NAME=门窗助手

# -------------------- 服务端口 --------------------
BACKEND_PORT=8000
FRONTEND_PORT=80
FRONTEND_HTTPS_PORT=443

# -------------------- 日志 --------------------
LOG_LEVEL=INFO
