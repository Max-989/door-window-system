[flake8]
max-line-length = 88
extend-ignore = E501, F841, W391, W292, F401
per-file-ignores = 
    # 这些文件是生成的或测试数据，可以有一些未使用导入
    seed_data.py:F401,
    verify_data.py:F401,
    # 测试文件中的未使用导入可以接受
    tests/*.py:F401,
    # 迁移文件可能没有换行符
    */migrations/*.py:W292,
    # 配置文件中的星号导入是Django标准模式
    config/settings/dev.py:F405