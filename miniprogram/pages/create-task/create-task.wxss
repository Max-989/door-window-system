/* 创建任务样式 */
.type-select { display: flex; gap: 16rpx; }
.type-option {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  font-size: 28rpx;
  transition: all 0.3s;
}
.type-option.active {
  border-color: var(--accent);
  background: var(--accent-light);
  color: #A8893D;
  font-weight: 600;
  box-shadow: 0 0 0 2rpx rgba(201, 169, 110, 0.2);
}

.photo-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.photo-item { width: 160rpx; height: 160rpx; border-radius: 12rpx; overflow: hidden; position: relative; }
.photo-item image { width: 100%; height: 100%; }
.photo-del {
  position: absolute; top: 0; right: 0; width: 40rpx; height: 40rpx;
  background: rgba(0,0,0,0.5); color: #fff; text-align: center; line-height: 40rpx;
  font-size: 24rpx; border-radius: 0 12rpx 0 12rpx; backdrop-filter: blur(4px);
}
.photo-add {
  width: 160rpx; height: 160rpx; border: 2rpx dashed var(--accent);
  border-radius: 12rpx; display: flex; align-items: center; justify-content: center;
  font-size: 44rpx; color: var(--accent); background: var(--accent-light);
}
