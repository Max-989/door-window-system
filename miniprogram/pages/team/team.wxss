/* 团队管理 · 黑金Apple HIG */
.page-team {
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  background: var(--bg);
}

/* 搜索栏（page-specific wrapper，全局已有 .search-bar margin） */
.search-input-wrap {
  align-items: center;
  background: var(--card);
  border-radius: var(--radius-lg);
  padding: 20rpx 24rpx;
  box-shadow: var(--shadow-card);
}
.search-icon { font-size: 28rpx; margin-right: 16rpx; }
.search-input { flex: 1; font-size: 28rpx; color: var(--text-primary); }

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
  overflow-x: auto;
}
.filter-tab {
  padding: 12rpx 32rpx;
  border-radius: var(--radius-xl);
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
  background: var(--card);
  white-space: nowrap;
  transition: all 0.2s ease;
  box-shadow: var(--shadow-card);
}
.filter-tab.active {
  background: var(--primary);
  color: var(--accent);
  box-shadow: 0 4rpx 16rpx rgba(26, 26, 46, 0.2);
}
.filter-tab:active { transform: scale(0.95); }

/* 统计 */
.stats-card .stat-num.accent { color: var(--accent); }

/* 成员卡片 */
.member-card { padding: 28rpx 32rpx; }
.member-info { display: flex; align-items: center; flex: 1; }
.member-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(201,169,110,0.1);
  color: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 600;
  margin-right: 24rpx;
  flex-shrink: 0;
  border: 2rpx solid rgba(201,169,110,0.2);
  transition: all 0.2s ease;
}
.member-avatar.online {
  border-color: var(--success);
  box-shadow: 0 0 0 4rpx rgba(52,199,89,0.15);
}
.member-detail { flex: 1; }
.member-name-row { display: flex; align-items: center; gap: 12rpx; }
.member-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.member-status {
  font-size: 22rpx;
  color: var(--text-hint);
  background: #F2F2F7;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-xl);
}
.member-status.online { color: var(--success); background: rgba(52,199,89,0.1); }
.member-skills {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  display: block;
}
.member-stats {
  font-size: 22rpx;
  color: var(--text-hint);
  margin-top: 6rpx;
  display: block;
}
.member-actions { display: flex; align-items: center; margin-left: 16rpx; }
.btn-call {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(201,169,110,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  transition: all 0.2s ease;
}
.btn-call:active { background: rgba(201,169,110,0.2); transform: scale(0.9); }
