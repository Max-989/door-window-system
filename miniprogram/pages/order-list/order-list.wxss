/* 订单列表样式 */
.search-inner {
  display: flex;
  align-items: center;
  background: var(--card);
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
  box-shadow: var(--shadow-card);
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; opacity: 0.5; }
.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  background: transparent;
}
.search-placeholder { color: #C7C7CC; }

/* 横向滚动筛选 */
.filter-scroll {
  margin-bottom: 24rpx;
  white-space: nowrap;
}
.filter-tabs-scroll {
  display: inline-flex;
  gap: 12rpx;
  padding: 6rpx 0;
}
.filter-tab {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--card);
  box-shadow: var(--shadow-card);
  font-weight: 500;
  transition: all 0.2s;
  white-space: nowrap;
}
.filter-tab.active {
  background: var(--accent);
  color: #fff;
  font-weight: 600;
  box-shadow: var(--shadow-accent);
}

.order-card { padding: 28rpx 32rpx; margin-bottom: 16rpx; }
.order-card:active { background: #FAFAFA; }
.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.order-no {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: 500;
}
.order-body { display: flex; flex-direction: column; }
.order-customer-row { margin-bottom: 8rpx; }
.order-customer {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}
.order-addr {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.order-products {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 2rpx;
}
.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
}
.order-date { font-size: 24rpx; color: var(--text-secondary); }
.order-total {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--accent);
}
