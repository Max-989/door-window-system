/* 任务详情样式 */
.task-type-label { font-size: 24rpx; color: rgba(255, 255, 255, 0.6); }

.remark-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
}
.no-photos {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-top: 8rpx;
}
.extra-display {
  padding: 12rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.extra-display:last-child { border-bottom: none; }
.extra-name { font-size: 28rpx; font-weight: 500; color: var(--text-primary); }
.extra-desc { font-size: 24rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }
