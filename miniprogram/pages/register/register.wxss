/* 注册页 · 黑金Apple HIG */
:root {
  --primary: #1A1A2E;
  --gold: #C9A96E;
  --gold-dark: #A88B52;
}

.register-page {
  min-height: 100vh;
  background: var(--primary);
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.register-glow {
  position: absolute;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(201,169,110,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.register-content {
  position: relative;
  z-index: 1;
  width: 100%;
  padding: 32rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 身份选择Tab */
.identity-tabs {
  display: flex;
  gap: 16rpx;
  width: 100%;
  margin-bottom: 40rpx;
}

.identity-tab {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 28rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}

.identity-tab.active {
  background: rgba(201, 169, 110, 0.15);
  border-color: #C9A96E;
  box-shadow: 0 4rpx 20rpx rgba(201, 169, 110, 0.25);
}

.identity-label {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.identity-tab.active .identity-label {
  color: #C9A96E;
}

.identity-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  margin-top: 8rpx;
  text-align: center;
}

.identity-tab.active .identity-desc {
  color: rgba(201, 169, 110, 0.7);
}

/* 注册卡片 */
.register-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 48rpx 40rpx;
}

/* 输入组 */
.input-group {
  margin-bottom: 28rpx;
}

.input-label {
  display: block;
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  font-size: 28rpx;
  color: #FFFFFF;
  box-sizing: border-box;
}

.input-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
}

.input-col {
  flex: 1;
}

.input-col .input-field {
  width: 100%;
}

.btn-get-code-wrap {
  display: flex;
  align-items: flex-end;
  padding-bottom: 0;
  height: 100%;
}

.btn-get-code {
  width: 160rpx;
  height: 80rpx;
  background: rgba(201, 169, 110, 0.2);
  border: 1rpx solid rgba(201, 169, 110, 0.4);
  border-radius: 16rpx;
  color: #C9A96E;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  white-space: nowrap;
}

.btn-get-code.disabled {
  opacity: 0.5;
}

/* 分隔线 */
.section-divider {
  display: flex;
  align-items: center;
  margin: 36rpx 0 28rpx;
  gap: 16rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(255, 255, 255, 0.1);
}

.divider-text {
  color: rgba(255, 255, 255, 0.35);
  font-size: 22rpx;
  white-space: nowrap;
}

/* 角色切换 */
.role-switch {
  margin-bottom: 28rpx;
}

.role-btns {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.role-btn {
  flex: 1;
  height: 76rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}

.role-btn.active {
  background: rgba(201, 169, 110, 0.15);
  border-color: #C9A96E;
  color: #C9A96E;
}

/* 协议 */
.agreement-row {
  margin-top: 40rpx;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.agree-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.agree-checkbox {
  transform: scale(0.7);
}

.agree-text {
  color: rgba(255, 255, 255, 0.5);
  font-size: 22rpx;
}

.agree-link {
  color: #C9A96E;
  font-size: 22rpx;
}

/* 注册按钮 */
.btn-register {
  width: 100%;
  background: linear-gradient(135deg, #C9A96E 0%, #A88B52 100%);
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 30rpx 0;
  border: none;
  line-height: 1;
  box-shadow: 0 8rpx 24rpx rgba(201, 169, 110, 0.35);
  letter-spacing: 8rpx;
  margin-top: 36rpx;
}

.btn-register::after {
  border: none;
}

.btn-register:active {
  opacity: 0.85;
  transform: scale(0.98);
  transition: all 0.15s;
}

/* 底部链接 */
.bottom-link {
  margin-top: 48rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.bottom-text {
  color: rgba(255, 255, 255, 0.4);
  font-size: 26rpx;
}

.bottom-link-text {
  color: #C9A96E;
  font-size: 26rpx;
}
