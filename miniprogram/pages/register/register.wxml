<!-- 注册页 · 黑金风格 · 三种注册流程 -->
<view class="register-page">
  <view class="register-glow"></view>

  <view class="register-content">
    <!-- 身份选择Tab -->
    <view class="identity-tabs">
      <view
        class="identity-tab {{selectedIdentity === 0 ? 'active' : ''}}"
        bindtap="onSelectIdentity"
        data-index="0"
      >
        <text class="identity-label">装企</text>
        <text class="identity-desc">项目经理 / 导购</text>
      </view>
      <view
        class="identity-tab {{selectedIdentity === 1 ? 'active' : ''}}"
        bindtap="onSelectIdentity"
        data-index="1"
      >
        <text class="identity-label">乙方</text>
        <text class="identity-desc">安装/量尺/维修</text>
      </view>
      <view
        class="identity-tab {{selectedIdentity === 2 ? 'active' : ''}}"
        bindtap="onSelectIdentity"
        data-index="2"
      >
        <text class="identity-label">客户</text>
        <text class="identity-desc">订单跟踪</text>
      </view>
    </view>

    <!-- 注册表单卡片 -->
    <view class="register-card">
      <!-- 姓名 -->
      <view class="input-group">
        <text class="input-label">姓名</text>
        <input class="input-field" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
      </view>

      <!-- 手机号 -->
      <view class="input-group">
        <text class="input-label">手机号</text>
        <input class="input-field" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" />
      </view>

      <!-- 密码（装企/乙方显示，客户不显示） -->
      <block wx:if="{{selectedIdentity !== 2}}">
        <view class="input-group">
          <text class="input-label">密码</text>
          <input class="input-field" password placeholder="请输入密码（不少于6位）" value="{{password}}" bindinput="onPasswordInput" />
        </view>
        <view class="input-group">
          <text class="input-label">确认密码</text>
          <input class="input-field" password placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
        </view>
      </block>

      <!-- 验证码（仅客户显示） -->
      <block wx:if="{{selectedIdentity === 2}}">
        <view class="input-group input-row">
          <view class="input-col">
            <text class="input-label">验证码</text>
            <input class="input-field" type="number" maxlength="6" placeholder="请输入验证码" value="{{verifyCode}}" bindinput="onCodeInput" />
          </view>
          <view class="btn-get-code-wrap">
            <view class="btn-get-code {{codeCountdown > 0 ? 'disabled' : ''}}" bindtap="onGetCode">
              {{codeCountdown > 0 ? codeCountdown + 's' : '获取'}}
            </view>
          </view>
        </view>
      </block>

      <!-- 仅装企：角色选择 + 装企信息 -->
      <block wx:if="{{selectedIdentity === 0}}">
        <view class="section-divider">
          <text class="divider-line"></text>
          <text class="divider-text">装企信息</text>
          <text class="divider-line"></text>
        </view>
        <view class="role-switch">
          <text class="input-label">角色</text>
          <view class="role-btns">
            <view class="role-btn {{role === '项目经理' ? 'active' : ''}}" bindtap="onSelectRole" data-role="项目经理">项目经理</view>
            <view class="role-btn {{role === '导购' ? 'active' : ''}}" bindtap="onSelectRole" data-role="导购">导购</view>
          </view>
        </view>
        <view class="input-group">
          <text class="input-label">装企名称</text>
          <input class="input-field" placeholder="请输入装企名称" value="{{companyName}}" bindinput="onCompanyNameInput" />
        </view>
        <view class="input-group">
          <text class="input-label">品牌名称</text>
          <input class="input-field" placeholder="请输入品牌名称" value="{{brandName}}" bindinput="onBrandNameInput" />
        </view>
      </block>

      <!-- 协议 -->
      <view class="agreement-row">
        <checkbox-group bindchange="onAgreeChange">
          <label class="agree-label">
            <checkbox class="agree-checkbox" checked="{{agreed}}" color="#C9A96E" />
            <text class="agree-text">我已阅读并同意</text>
          </label>
        </checkbox-group>
        <text class="agree-link" bindtap="onViewAgreement">《用户协议》和《隐私政策》</text>
      </view>

      <!-- 注册按钮 -->
      <button class="btn-register" bindtap="onRegister" loading="{{loading}}">
        注 册
      </button>
    </view>

    <!-- 底部链接 -->
    <view class="bottom-link" bindtap="goToLogin">
      <text class="bottom-text">已有账号？</text>
      <text class="bottom-link-text">立即登录</text>
    </view>
  </view>
</view>
