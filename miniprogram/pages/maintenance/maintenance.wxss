/* 维修申请页样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding: 0 0 16rpx;
}
.task-card { padding: 28rpx 32rpx; margin-bottom: 16rpx; }
.task-card:active { background: #FAFAFA; }
.task-header { display: flex; justify-content: space-between; margin-bottom: 12rpx; }
.task-id { font-size: 24rpx; color: var(--text-secondary); font-weight: 500; }
.task-body { display: flex; flex-direction: column; }
.task-customer { font-size: 28rpx; margin-bottom: 6rpx; color: var(--text-primary); }
.task-addr {
  font-size: 24rpx;
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.task-time { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }
.task-footer {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border);
}
.resp-badge {
  font-size: 24rpx;
  color: var(--danger);
  font-weight: 500;
  background: #FFF0F0;
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}
