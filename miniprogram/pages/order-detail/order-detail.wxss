/* 订单详情样式 */
.status-badge {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(255, 255, 255, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}
.status-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.product-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.product-name { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.product-qty {
  color: var(--accent);
  font-size: 26rpx;
  font-weight: 500;
  background: var(--accent-light);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.product-spec {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: block;
  line-height: 1.8;
}

.product-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.product-item:last-child { border-bottom: none; }

.progress-steps {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}
.step {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 80rpx;
}
.step-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--border);
  transition: all 0.3s;
}
.step.done .step-dot {
  background: var(--accent);
  box-shadow: 0 0 8rpx rgba(201, 169, 110, 0.4);
}
.step.done { color: var(--accent); font-weight: 600; }
.step-line { flex: 1; height: 2rpx; background: var(--border); margin: 0 4rpx; margin-bottom: 30rpx; }
.step-line.done { background: var(--accent); }

.task-link {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  font-size: 28rpx;
}
.task-link + .task-link { border-top: 1rpx solid var(--border); }
.link-arrow { color: var(--accent); font-size: 40rpx; font-weight: 300; }
